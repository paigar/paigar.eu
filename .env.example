# Variables de entorno para `deno task publicar`.
# Copia este archivo a `.env` y rellena con las credenciales reales.
# El `.env` está en .gitignore, no se subirá al repo.

# ─── Bunny Storage (subida de ficheros) ────────────────────────────────
# Hostname de la región del Storage Zone. Suele ser uno de:
#   storage.bunnycdn.com         (default, EU)
#   ny.storage.bunnycdn.com      (New York)
#   la.storage.bunnycdn.com      (Los Angeles)
#   sg.storage.bunnycdn.com      (Singapore)
#   syd.storage.bunnycdn.com     (Sydney)
#   br.storage.bunnycdn.com      (Brazil)
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com

# Nombre del Storage Zone que has creado en Bunny.
BUNNY_STORAGE_ZONE_NAME=paigar-eu

# Password (Read+Write) del Storage Zone. Bunny → Storage → Zone → "FTP & API Access".
BUNNY_STORAGE_PASSWORD=

# ─── Bunny CDN Pull Zone (purga de caché tras subir) ───────────────────
# ID numérico de la Pull Zone que sirve paigar.eu desde el Storage.
# Lo encuentras en la URL del panel: bunny.net/pullzone/{ID}/...
BUNNY_PULL_ZONE_ID=

# Account API Key (no de la zone, sino de la cuenta).
# Bunny → Account Settings → API → API Key.
BUNNY_API_KEY=
