<div id="iban-prototipo">
  <div class="ib-card">
    <div class="ib-eyebrow">Herramienta · paigar.eu</div>
    <h3 class="ib-title">Valida tu <em>IBAN</em></h3>
    <p class="ib-subtitle">Introduce el número de cuenta y comprueba si es válido al instante.</p>

    <label class="ib-label" for="ib-input">Código IBAN</label>
    <div class="ib-input-row">
      <input id="ib-input" type="text" maxlength="42" placeholder="ES91 2100 0418 4502 0005 1332" autocomplete="off" spellcheck="false">
      <button class="ib-clear-btn" id="ib-clearBtn">Limpiar</button>
    </div>

    <div class="ib-result-card" id="ib-resultCard">
      <div class="ib-result-dot"></div>
      <div class="ib-result-body">
        <div class="ib-result-tipo" id="ib-resultTipo">—</div>
        <div class="ib-result-msg" id="ib-resultMsg">Escribe un IBAN para validarlo</div>
      </div>
    </div>

    <div class="ib-desglose" id="ib-desglose">
      <div class="ib-desglose-title">Desglose</div>
      <div class="ib-desglose-row"><div class="ib-desglose-key">País</div><div class="ib-desglose-val" id="ib-dPais">—</div></div>
      <div class="ib-desglose-row"><div class="ib-desglose-key">Dígitos de control</div><div class="ib-desglose-val" id="ib-dControl">—</div></div>
      <div class="ib-desglose-row"><div class="ib-desglose-key">BBAN</div><div class="ib-desglose-val" id="ib-dBBAN">—</div></div>
      <div class="ib-desglose-row"><div class="ib-desglose-key">Longitud</div><div class="ib-desglose-val" id="ib-dLongitud">—</div></div>
      <div class="ib-desglose-row"><div class="ib-desglose-key">Módulo 97</div><div class="ib-desglose-val" id="ib-dMod">—</div></div>
    </div>

    <div class="ib-sep"></div>

    <div class="ib-examples-label">Ejemplos</div>
    <div class="ib-chips">
      <div class="ib-chip ib-ok" data-value="ES9121000418450200051332"><span class="ib-chip-label">ES</span>ES9121000418450200051332</div>
      <div class="ib-chip ib-ok" data-value="DE89370400440532013000"><span class="ib-chip-label">DE</span>DE89370400440532013000</div>
      <div class="ib-chip ib-ok" data-value="GB29NWBK60161331926819"><span class="ib-chip-label">GB</span>GB29NWBK60161331926819</div>
      <div class="ib-chip ib-ok" data-value="FR7630006000011234567890189"><span class="ib-chip-label">FR</span>FR7630006000011234567890189</div>
      <div class="ib-chip ib-ko" data-value="ES0021000418450200051332"><span class="ib-chip-label">inválido</span>ES0021000418450200051332</div>
      <div class="ib-chip ib-ko" data-value="ES9121000418450200051333"><span class="ib-chip-label">inválido</span>ES9121000418450200051333</div>
    </div>

    <p class="ib-footer-note">Validación realizada en el navegador · ningún dato se envía a ningún servidor</p>
  </div>
</div>

<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap');

#iban-prototipo {
  --ib-ink: #1a1a2e;
  --ib-paper: #f5f0e8;
  --ib-accent: #c8321f;
  --ib-accent-soft: #f0e0dd;
  --ib-ok: #1a6b3c;
  --ib-ok-soft: #d4edde;
  --ib-mid: #6b5b3e;
  --ib-border: #c8b89a;
  --ib-mono: 'DM Mono', monospace;
  --ib-serif: 'DM Serif Display', serif;
  --ib-sans: 'DM Sans', sans-serif;
  display: flex;
  justify-content: center;
  padding: 2rem 0;
  font-family: var(--ib-sans);
  color: var(--ib-ink);
}

#iban-prototipo * {
  box-sizing: border-box;
}

#iban-prototipo .ib-card {
  background: white;
  border: 1.5px solid var(--ib-border);
  border-radius: 2px;
  padding: 3rem 3.5rem;
  width: 100%;
  position: relative;
  box-shadow: 6px 6px 0 var(--ib-border);
}

#iban-prototipo .ib-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 4px;
  background: linear-gradient(90deg, var(--ib-accent) 0%, var(--ib-ink) 50%, var(--ib-ok) 100%);
}

