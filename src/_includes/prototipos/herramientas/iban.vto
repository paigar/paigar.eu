  flex: 1;
  font-family: var(--ib-mono);
  font-size: 1.1rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.8rem 1rem;
  border: 1.5px solid var(--ib-border);
  border-radius: 2px;
  background: var(--ib-paper);
  color: var(--ib-ink);
  outline: none;
  transition: border-color 0.2s, background 0.2s;
}

#iban-prototipo input:focus {
  border-color: var(--ib-ink);
  background: white;
}

