{{ set ebTags = (post.tags || []).filter(t => t !== 'post') }}

<article class="post-card">

  <a class="post-card-cover" href="{{ post.url }}" tabindex="-1" aria-hidden="true">
    {{ if post.image }}
      {{ cardPicture(post.image, "", false, false) }}
    {{ else }}
      <div class="post-card-poster">
        <span class="post-card-poster-letter">{{ post.title.charAt(0) }}.</span>
      </div>
    {{ /if }}
  </a>

  <div class="post-card-body">

    {{ if ebTags.length && !compact }}
      <div class="post-card-eyebrow">
        {{ for i, tag of ebTags }}<a href="/etiqueta/{{ tag |> slug }}/">{{ tag }}</a>{{ if i < ebTags.length - 1 }}<span class="sep">·</span>{{ /if }}{{ /for }}
      </div>
    {{ /if }}

    <h2 class="post-card-title">
      <a href="{{ post.url }}">{{ post.title }}</a>
    </h2>

    {{ if post.excerpt && !compact }}
      <p class="post-card-excerpt">{{ post.excerpt }}</p>
    {{ /if }}

    {{ if !compact }}
      <a href="{{ post.url }}" class="post-card-readmore" aria-label="Leer {{ post.title }}">
        Leer <span class="arrow">→</span>
      </a>
    {{ /if }}

  </div>

</article>
